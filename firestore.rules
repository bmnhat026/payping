rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user đã đăng nhập
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: doc thuộc về user hiện tại
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // cards: chỉ owner mới đọc/ghi
    match /cards/{cardId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // transactions (giao dịch chi tiêu, ghi nợ vào thẻ)
    match /transactions/{txId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // loans (khoản cho vay)
    match /loans/{loanId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // loanRepayments (lịch sử trả của từng khoản vay)
    match /loanRepayments/{repId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // notes (ghi chú độc lập)
    match /notes/{noteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // cardNotes (ghi chú gắn theo thẻ)
    match /cardNotes/{noteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
